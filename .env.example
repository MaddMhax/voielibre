# Copiez ce fichier en ".env" et renseignez vos valeurs.
# Le fichier .env est ignoré par git : vos secrets n'y seront jamais commités.

# --- Requis ---

# Clé API SNCF (voir README §1 — https://numerique.sncf.com/startup/api/)
SNCF_API_KEY=

# Mot de passe du menu d'administration. AUCUNE valeur par défaut :
# sans lui, l'administration est désactivée et le conteneur refuse de démarrer.
ADMIN_PASSWORD=

# --- Recommandé ---

# Identifiant du menu d'administration
ADMIN_USERNAME=admin

# Route (secrète) du panneau d'administration — choisissez la vôtre
ADMIN_PATH=/voielibre-admin

# Clé de signature des sessions (openssl rand -hex 32).
# Si absente : clé aléatoire éphémère à chaque démarrage (sessions perdues au restart).
SECRET_KEY=

# Adresse d'écoute. Défaut 127.0.0.1 (derrière un proxy type Caddy) ;
# mettre 0.0.0.0 pour exposer directement sur le réseau.
BIND_ADDR=127.0.0.1

# Cookie de session marqué "Secure" — mettre à true derrière un proxy HTTPS
SESSION_HTTPS_ONLY=false

# --- Optionnel ---

# Heure (0-23) qui sépare l'affichage "matin" et "soir"
MORNING_EVENING_CUTOFF=14

# Plafonds de l'offre gratuite de l'API SNCF (affichage quota + warning public)
SNCF_API_DAILY_QUOTA=5000
SNCF_API_MONTHLY_QUOTA=150000

# Notifications ntfy (laisser vide pour désactiver, voir README).
# URL complète du topic, ex. https://ntfy.sh/mon-topic-voie-libre
NTFY_URL=

# Authentification ntfy (optionnel — uniquement si le topic est protégé ou
# si vous utilisez un serveur ntfy privé avec contrôle d'accès).
# Méthode recommandée : un jeton d'accès (créé via `ntfy token add <user>`,
# ou dans l'interface web > Account > Access tokens). Prioritaire s'il est
# renseigné. Topic public : laisser tout vide.
NTFY_TOKEN=
# Alternative au jeton : identifiant + mot de passe d'un compte ntfy.
NTFY_USERNAME=
NTFY_PASSWORD=

# Analytics Ackee (laisser vide pour désactiver, voir README)
ACKEE_URL=
ACKEE_DOMAIN_ID=
